# API Keys
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Transcript API (Optional - has fallback)
TRANSCRIPT_API_KEY=your_transcript_api_key_here

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost/skillvid_db

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging
LOG_LEVEL=INFO

# JWT Authentication  (generate with: openssl rand -hex 32)
SECRET_KEY=changeme-replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
